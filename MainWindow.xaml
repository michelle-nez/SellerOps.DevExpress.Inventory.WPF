<Window x:Class="SellerOps.DevExpress.Inventory.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        Title="SellerOps Inventory Dashboard"
        Height="720"
        Width="1120"
        MinHeight="620"
        MinWidth="960">
      <DockPanel Background="#F6F8FB">
            <Border DockPanel.Dock="Top"
                    Background="White"
                    Padding="22"
                    BorderBrush="#D9E2F3"
                    BorderThickness="0,0,0,1">
                  <StackPanel>
                        <TextBlock Text="SellerOps Inventory Dashboard"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#1F4E79" />
                        <TextBlock Text="DevExpress WPF sample for editable marketplace inventory data"
                                   Margin="0,4,0,0"
                                   Foreground="#5F6B7A" />
                  </StackPanel>
            </Border>

            <Grid Margin="22">
                  <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                  </Grid.RowDefinitions>

                  <UniformGrid Grid.Row="0"
                               Columns="4"
                               Margin="0,0,0,16">
                        <Border Background="White"
                                Padding="16"
                                Margin="0,0,10,0"
                                BorderBrush="#D9E2F3"
                                BorderThickness="1"
                                CornerRadius="10">
                              <StackPanel>
                                    <TextBlock Text="Total Products"
                                               Foreground="#5F6B7A" />
                                    <TextBlock Text="{Binding TotalProducts}"
                                               FontSize="26"
                                               FontWeight="SemiBold" />
                              </StackPanel>
                        </Border>

                        <Border Background="White"
                                Padding="16"
                                Margin="0,0,10,0"
                                BorderBrush="#D9E2F3"
                                BorderThickness="1"
                                CornerRadius="10">
                              <StackPanel>
                                    <TextBlock Text="Low Stock"
                                               Foreground="#5F6B7A" />
                                    <TextBlock Text="{Binding LowStockCount}"
                                               FontSize="26"
                                               FontWeight="SemiBold" />
                              </StackPanel>
                        </Border>

                        <Border Background="White"
                                Padding="16"
                                Margin="0,0,10,0"
                                BorderBrush="#D9E2F3"
                                BorderThickness="1"
                                CornerRadius="10">
                              <StackPanel>
                                    <TextBlock Text="Needs Review"
                                               Foreground="#5F6B7A" />
                                    <TextBlock Text="{Binding ReviewCount}"
                                               FontSize="26"
                                               FontWeight="SemiBold" />
                              </StackPanel>
                        </Border>

                        <Border Background="White"
                                Padding="16"
                                BorderBrush="#D9E2F3"
                                BorderThickness="1"
                                CornerRadius="10">
                              <StackPanel>
                                    <TextBlock Text="Inventory Value"
                                               Foreground="#5F6B7A" />
                                    <TextBlock Text="{Binding InventoryValue, StringFormat=C}"
                                               FontSize="26"
                                               FontWeight="SemiBold" />
                              </StackPanel>
                        </Border>
                  </UniformGrid>

                  <StackPanel Grid.Row="1"
                              Orientation="Horizontal"
                              Margin="0,0,0,12">
                        <Button Content="Add Sample Product"
                                Command="{Binding AddProductCommand}"
                                Padding="14,8"
                                Margin="0,0,8,0" />
                        <Button Content="Delete Selected"
                                Command="{Binding DeleteSelectedCommand}"
                                Padding="14,8" />
                  </StackPanel>

                  <Border Grid.Row="2"
                          Background="White"
                          BorderBrush="#D9E2F3"
                          BorderThickness="1"
                          CornerRadius="10"
                          Padding="12">
                        <dxg:GridControl ItemsSource="{Binding Products}"
                                         SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                                         AutoGenerateColumns="None">
                              <dxg:GridControl.TotalSummary>
                                    <dxg:GridSummaryItem FieldName="Quantity"
                                                         SummaryType="Sum"
                                                         DisplayFormat="Total Units: {0}" />
                                    <dxg:GridSummaryItem FieldName="Price"
                                                         SummaryType="Average"
                                                         DisplayFormat="Average Price: {0:C}" />
                              </dxg:GridControl.TotalSummary>

                              <dxg:GridControl.Columns>
                                    <dxg:GridColumn FieldName="Sku"
                                                    Header="SKU"
                                                    Width="130" />
                                    <dxg:GridColumn FieldName="Title"
                                                    Header="Product Title"
                                                    Width="260" />
                                    <dxg:GridColumn FieldName="Marketplace"
                                                    Header="Marketplace"
                                                    Width="120" />
                                    <dxg:GridColumn FieldName="Quantity"
                                                    Header="Qty"
                                                    Width="80" />
                                    <dxg:GridColumn FieldName="Price"
                                                    Header="Price"
                                                    Width="90" />
                                    <dxg:GridColumn FieldName="Status"
                                                    Header="Status"
                                                    Width="130">
                                          <dxg:GridColumn.EditSettings>
                                                <dxe:ComboBoxEditSettings ItemsSource="{Binding StatusOptions}" />
                                          </dxg:GridColumn.EditSettings>
                                    </dxg:GridColumn>
                                    <dxg:GridColumn FieldName="LastUpdated"
                                                    Header="Last Updated"
                                                    Width="130" />
                              </dxg:GridControl.Columns>

                              <dxg:GridControl.View>
                                    <dxg:TableView AllowEditing="True"
                                                   AutoWidth="True"
                                                   NewItemRowPosition="Top"
                                                   ShowGroupPanel="True"
                                                   ShowSearchPanelMode="Always"
                                                   ShowTotalSummary="True" />
                              </dxg:GridControl.View>
                        </dxg:GridControl>
                  </Border>
            </Grid>
      </DockPanel>
</Window>